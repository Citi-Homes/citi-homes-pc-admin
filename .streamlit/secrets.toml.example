[microsoft]
tenant_id = "YOUR_AZURE_TENANT_ID"
client_id = "YOUR_AZURE_APP_CLIENT_ID"
client_secret = "YOUR_AZURE_APP_CLIENT_SECRET"
site_id = "YOUR_SHAREPOINT_SITE_ID"

[auth]
redirect_uri = "http://localhost:8503/oauth2callback"
cookie_secret = "GENERATE_A_LONG_RANDOM_COOKIE_SECRET"
client_id = "YOUR_AZURE_APP_CLIENT_ID"
client_secret = "YOUR_AZURE_APP_CLIENT_SECRET"
server_metadata_url = "https://login.microsoftonline.com/YOUR_AZURE_TENANT_ID/v2.0/.well-known/openid-configuration"

[app_access]
allowed_domains = ["citihomes.ae"]
admins = ["umer@citihomes.ae"]
management = []
default_role = "Admin"

[microsoft_lists]
employees = "EMPLOYEE_MASTER_LIST_ID"
recruitment = "RECRUITMENT_TRACKER_LIST_ID"
interview_evaluation = "INTERVIEW_EVALUATION_LIST_ID"
vendors = "VENDOR_DATABASE_LIST_ID"
pantry = "PANTRY_MANAGEMENT_LIST_ID"
tasks = "PC_TASK_CALENDAR_LIST_ID"

[supabase]
url = "https://YOUR_PROJECT.supabase.co"
service_role_key = "YOUR_SUPABASE_SERVICE_ROLE_KEY"

[data]
backend = "supabase"
